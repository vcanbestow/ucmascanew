<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /ucmasnext/

  # If the requested URL is an existing file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # If an HTML file exists, serve it (Fallback)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
  
  # Handle 404 errors using the Next.js 404 page
  ErrorDocument 404 /ucmasnext/404.html
</IfModule>